type TimerId = nat;
type Time = nat;
type Stats = 
 record {
   cycles: nat;
   expectedExecutionTime: opt Time;
   lastExecutionTime: Time;
   maxExecutions: nat;
   minAction: opt ActionDetail;
   nextActionId: nat;
   nextTimer: opt TimerId;
   timers: nat;
 };
type OVSTestCanisterV2 = 
 service {
   /// Add an async action
   addAsyncAction: (time: nat, actionType: text, paramsNat: opt nat, timeout:
    nat) -> (ActionId);
   /// Add a sync action
   addSyncAction: (time: nat, actionType: text, paramsNat: opt nat) ->
    (ActionId);
   /// Cancel an action
   cancelAction: (actionId: nat) -> (opt nat);
   /// Get counter value
   getCounter: () -> (nat) query;
   /// Get error count
   getErrorCount: () -> (nat) query;
   /// Get executed action count
   getExecutedCount: () -> (nat) query;
   /// Get execution history
   getExecutionHistory: () -> (vec record {
                                     nat;
                                     text;
                                     nat;
                                   }) query;
   /// Get OVS-specific stats
   getOVSStats: () ->
    (record {
       cycleShareCount: nat;
       cyclesBalance: nat;
       lastActionIdReported: opt nat;
       lastCycleReport: opt nat;
       lastCycleShareTime: nat;
       nextCycleActionId: opt nat;
     }) query;
   /// Get timer stats
   getStats: () -> (Stats) query;
   /// Get current time in nanoseconds
   getTime: () -> (nat) query;
   /// Get raw timer state for debugging
   getTimerState: () ->
    (record {
       lastActionIdReported: opt nat;
       lastCycleReport: opt nat;
       nextActionId: nat;
       nextCycleActionId: opt nat;
     }) query;
   getUpgradeCount: () -> (nat) query;
   incrementUpgradeCount: () -> ();
   /// Force re-initialization (for testing)
   initialize: () -> ();
   /// Reset test state
   resetTestState: () -> ();
   /// Update collector
   updateCollector: (collector: opt principal) -> ();
   /// Update OVS period (for testing shorter cycles)
   updateOVSPeriod: (period: nat) -> ();
   version: () -> (text) query;
 };
type ActionId = 
 record {
   id: nat;
   time: Time;
 };
type ActionDetail = 
 record {
   ActionId;
   Action;
 };
type Action = 
 record {
   aSync: opt nat;
   actionType: text;
   params: blob;
   retries: nat;
 };
/// OVSTestCanisterV2 - Test canister V2 with OVS enabled for upgrade testing
/// 
/// This canister is a second version to test upgrade scenarios:
/// - Same functionality as V1 plus additional features
/// - Used to verify upgrades don't cause duplicate timers or OVS allocations
service : (_args: opt record {
                        collector: opt principal;
                        period: opt nat;
                      }) -> OVSTestCanisterV2
